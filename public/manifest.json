{
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "version": "1.0.1",
  "description": "__MSG_extDescription__",
  "author": "Anastasia Nesterova",
  "homepage_url": "https://github.com/AnastasyaNN/QA-Trace",

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "webNavigation",
    "alarms",
    "clipboardWrite"
  ],

  "{{chrome}}.host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "{{chrome}}.background": {
    "service_worker": "src/background/service-worker.js"
  },
  "{{firefox}}.background": {
    "scripts": ["src/background/service-worker.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/content-script.js"
      ],
      "run_at": "document_start"
    }
  ],

  "{{chrome}}.action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_actionTitle__"
  },
  "{{firefox}}.browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_actionTitle__"
  },

  "{{chrome}}.web_accessible_resources": [
    {
      "resources": ["assets/*", "src/page-hooks/page-hooks.js"],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],
  "{{firefox}}.web_accessible_resources": ["assets/*", "src/page-hooks/page-hooks.js"],

  "{{firefox}}.browser_specific_settings": {
    "gecko": {
      "id": "qa-trace@anastasia-nesterova",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
