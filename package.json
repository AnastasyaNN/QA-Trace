{
  "name": "qa_trace",
  "version": "1.0.2",
  "description": "Track user actions, monitor errors and prepare prompts to generate bug reports and exploratory testing report",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && npm run build:chromium && npm run build:firefox",
    "build:chromium": "cross-env TARGET=chrome vite build",
    "build:firefox": "cross-env TARGET=firefox vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "retire": "retire --path dist --nocache --verbose --colors"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/webextension-polyfill": "^0.12.5",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-web-extension": "^4.5.1",
    "npm-check-updates": "^22.2.1",
    "vitest": "^4.1.7",
    "retire": "^5.4.3"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "AGPL-3.0",
  "author": "Anastasia Nesterova",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnastasyaNN/QA-Trace"
  },
  "keywords": [
    "qa",
    "testing",
    "exploratory-testing",
    "bug-reporting",
    "error-monitoring",
    "action-tracking",
    "test-documentation",
    "browser-extension",
    "webextension",
    "automation"
  ]
}
